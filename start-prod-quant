#!/usr/bin/env bash
# 生产环境量化子系统独立启动脚本
# 功能：独立启动数据采集 Agent 和/或定时调度 Worker
#       可与 start-prod.sh 并行使用，不耦合 Web 前后端部署流程
#
# 用法：
#   ./start-prod-quant --agent      仅启动数据采集客户端
#   ./start-prod-quant --scheduler  仅启动定时调度 Worker
#   ./start-prod-quant --all        同时启动 Agent + Scheduler（默认）
#   ./start-prod-quant --restart    先停止现有进程再启动

set -euo pipefail

PROJECT_ROOT="$HOME/openai-project"
SERVER_DIR="$PROJECT_ROOT/cyf/project/server"
BACKEND_PORT=39997
SERVER_URL="http://127.0.0.1:${BACKEND_PORT}"

LOG_ROOT="$SERVER_DIR/logs"
QUANT_LOG_DIR="$LOG_ROOT/quant"
AGENT_LOG="$QUANT_LOG_DIR/agent.log"
SCHEDULER_LOG="$QUANT_LOG_DIR/scheduler.log"

# 默认选项
START_AGENT=false
START_SCHEDULER=false
RESTART=false

show_help() {
    echo "用法: $0 [选项]"
    echo "选项:"
    echo "  --agent       仅启动数据采集 Agent（每15秒轮询任务）"
    echo "  --scheduler   仅启动定时调度 Worker（每30秒轮询）"
    echo "  --all         同时启动 Agent + Scheduler（默认）"
    echo "  --restart     重启模式：先终止现有量化进程再启动"
    echo "  --help        显示此帮助信息"
    echo ""
    echo "示例:"
    echo "  $0 --agent               # 仅启动采集 Agent"
    echo "  $0 --all                 # 启动全部量化服务"
    echo "  $0 --scheduler --restart # 重启调度 Worker"
    exit 0
}

for arg in "$@"; do
    case $arg in
        --agent)       START_AGENT=true ;;
        --scheduler)   START_SCHEDULER=true ;;
        --all)         START_AGENT=true; START_SCHEDULER=true ;;
        --restart)     RESTART=true ;;
        --help|-h)     show_help ;;
        *)             echo "未知参数: $arg"; show_help ;;
    esac
done

# 默认全部启动
if [ "$START_AGENT" = false ] && [ "$START_SCHEDULER" = false ]; then
    START_AGENT=true
    START_SCHEDULER=true
fi

# 生产 Python
PYTHON_BIN="python3"

stop_quant_processes() {
    echo "🔍 查找并停止现有量化进程..."

    # Agent
    AGENT_PIDS=$(pgrep -f "quant_data_agent\.py run-once" 2>/dev/null || true)
    if [ -n "$AGENT_PIDS" ]; then
        echo "⚠️  终止数据采集 Agent 进程: $AGENT_PIDS"
        kill $AGENT_PIDS 2>/dev/null || kill -9 $AGENT_PIDS 2>/dev/null || true
    fi

    # Scheduler
    SCHEDULER_PIDS=$(pgrep -f "quant_scheduler_worker\.py" 2>/dev/null || true)
    if [ -n "$SCHEDULER_PIDS" ]; then
        echo "⚠️  终止调度 Worker 进程: $SCHEDULER_PIDS"
        kill $SCHEDULER_PIDS 2>/dev/null || kill -9 $SCHEDULER_PIDS 2>/dev/null || true
    fi

    sleep 2
    echo "✅ 已有量化进程已清理"
}

# 重启模式
if [ "$RESTART" = true ]; then
    stop_quant_processes
fi

# 检查命令
check_command() {
    if ! command -v "$1" &> /dev/null; then
        echo "❌ 错误: 未找到命令 '$1'"
        exit 1
    fi
}
check_command "python3"

# PID 跟踪
AGENT_PID=""
SCHEDULER_PID=""

cleanup() {
    trap - INT TERM EXIT ERR
    echo ""
    echo "🛑 正在停止量化子系统..."

    if [ -n "$AGENT_PID" ] && kill -0 "$AGENT_PID" 2>/dev/null; then
        kill "$AGENT_PID" 2>/dev/null || true
        wait "$AGENT_PID" 2>/dev/null || true
    fi
    if [ -n "$SCHEDULER_PID" ] && kill -0 "$SCHEDULER_PID" 2>/dev/null; then
        kill "$SCHEDULER_PID" 2>/dev/null || true
        wait "$SCHEDULER_PID" 2>/dev/null || true
    fi

    # 兜底强制清理
    if [ -n "$AGENT_PID" ]; then
        kill -9 "$AGENT_PID" 2>/dev/null || true
    fi
    if [ -n "$SCHEDULER_PID" ]; then
        kill -9 "$SCHEDULER_PID" 2>/dev/null || true
    fi

    echo "👋 量化子系统已停止"
}

trap cleanup INT TERM EXIT
trap 'echo "❌ 脚本异常退出"; cleanup; exit 1' ERR

# 准备日志目录
mkdir -p "$QUANT_LOG_DIR"

echo "🚀 量化子系统生产环境启动"
echo "📡 后端地址: $SERVER_URL"
echo "📄 Agent 日志:     $AGENT_LOG"
echo "📄 Scheduler 日志: $SCHEDULER_LOG"
echo ""

# ── 数据采集 Agent ──
if [ "$START_AGENT" = true ]; then
    : > "$AGENT_LOG"
    (
        cd "$SERVER_DIR"
        while true; do
            "$PYTHON_BIN" worker/quant_data_agent.py run-once \
                --server-url "$SERVER_URL" \
                --client-id "prod-local-client" \
                --user admin \
                --password admin123 >>"$AGENT_LOG" 2>&1 || true
            sleep 15
        done
    ) &
    AGENT_PID=$!
    echo "✅ 数据采集 Agent 已启动 (PID: $AGENT_PID, 轮询间隔: 15s)"
fi

# ── 定时调度 Worker ──
if [ "$START_SCHEDULER" = true ]; then
    : > "$SCHEDULER_LOG"
    (
        cd "$SERVER_DIR"
        exec "$PYTHON_BIN" worker/quant_scheduler_worker.py
    ) >>"$SCHEDULER_LOG" 2>&1 &
    SCHEDULER_PID=$!
    echo "✅ 定时调度 Worker 已启动 (PID: $SCHEDULER_PID, 轮询间隔: ≤30s)"
fi

echo ""
echo "🎉 量化子系统启动完成！"
echo ""
echo "📊 运行状态："
if [ "$START_AGENT" = true ]; then
    echo "- 数据采集 Agent:  PID=$AGENT_PID, 日志=$AGENT_LOG"
fi
if [ "$START_SCHEDULER" = true ]; then
    echo "- 定时调度 Worker: PID=$SCHEDULER_PID, 日志=$SCHEDULER_LOG"
fi
echo ""
echo "🔧 管理命令："
echo "- 查看 Agent 日志:     tail -f $AGENT_LOG"
echo "- 查看 Scheduler 日志: tail -f $SCHEDULER_LOG"
echo "- 重启全部:            $0 --restart"
echo "- 终止全部:            Ctrl+C 或 kill $AGENT_PID $SCHEDULER_PID"
echo ""
echo "💡 按 Ctrl+C 退出并停止所有量化子进程"

# 等待任意子进程退出
if [ -n "$AGENT_PID" ] && [ -n "$SCHEDULER_PID" ]; then
    wait "$AGENT_PID" "$SCHEDULER_PID" 2>/dev/null || true
elif [ -n "$AGENT_PID" ]; then
    wait "$AGENT_PID" 2>/dev/null || true
elif [ -n "$SCHEDULER_PID" ]; then
    wait "$SCHEDULER_PID" 2>/dev/null || true
fi
